KEYCLOAK_BASE_URL=https://auth.local
KEYCLOAK_INTERNAL_URL=http://keycloak:8080
KEYCLOAK_REALM=auth_app
KEYCLOAK_CLIENT_ID=auth-app-bff
KEYCLOAK_CLIENT_SECRET=replace_me
KEYCLOAK_REDIRECT_URI=https://app.local/api/auth/callback

SESSION_REDIS_URL=redis://redis:6379/0
DATABASE_URL=postgresql+psycopg://appuser:apppassword@host.docker.internal:5432/appdb
ENTITIES_MODEL_PATH=app/generated/entities_model.json
SESSION_TTL_SECONDS=604800
LOGIN_STATE_TTL_SECONDS=900

APP_BASE_URL=https://app.local
API_BASE_URL=https://app.local/api
COOKIE_NAME=app_session
CSRF_COOKIE_NAME=csrf_token
COOKIE_SECURE=true
COOKIE_SAMESITE=none
COOKIE_DOMAIN=.local
SESSION_SIGNING_ACTIVE_KEY_ID=v1
SESSION_SIGNING_KEYS=v1:replace_me_with_a_long_random_secret
ALLOWED_CORS_ORIGINS=["https://app.local","http://app.local","https://localhost:3000","http://localhost:3000"]

SECURITY_HEADERS_ENABLED=true
GLOBAL_RATE_LIMIT_ENABLED=true
GLOBAL_RATE_LIMIT_REQUESTS=240
GLOBAL_RATE_LIMIT_WINDOW_SECONDS=60
AUTH_RATE_LIMIT_REQUESTS=30
AUTH_RATE_LIMIT_WINDOW_SECONDS=60
LOGIN_BRUTEFORCE_ATTEMPT_LIMIT=8
LOGIN_BRUTEFORCE_WINDOW_SECONDS=600
LOGIN_BRUTEFORCE_BLOCK_SECONDS=900

JOB_QUEUE_NAME=app_jobs
JOB_QUEUE_DELAYED_NAME=app_jobs_delayed
JOB_QUEUE_DEAD_LETTER_NAME=app_jobs_dead
JOB_WORKER_POLL_SECONDS=2
JOB_RETRY_BACKOFF_SECONDS=10
JOB_DEFAULT_MAX_ATTEMPTS=4
JOB_PROMOTE_BATCH_SIZE=50

WEBHOOK_DEFAULT_TIMEOUT_SECONDS=10
WEBHOOK_MAX_TIMEOUT_SECONDS=60

NOTIFICATION_PROVIDER=log
NOTIFICATION_FROM_EMAIL=no-reply@app.local
NOTIFICATION_TEMPLATES_DIR=app/notifications/templates
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_STARTTLS=true
SMTP_USE_SSL=false
SES_REGION_NAME=us-east-1
SES_CONFIGURATION_SET=

MEDIA_DIR=/app/uploads
MAX_AVATAR_MB=5
