KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

KC_DB_URL=jdbc:postgresql://host.docker.internal:5432/keycloak
KC_DB_USERNAME=keycloak
KC_DB_PASSWORD=password

KEYCLOAK_BASE_URL=https://auth.local
KEYCLOAK_INTERNAL_URL=http://keycloak:8080
KEYCLOAK_REALM=auth_app
KEYCLOAK_CLIENT_ID=auth-app-bff
KEYCLOAK_CLIENT_SECRET=replace_me
KEYCLOAK_REDIRECT_URI=https://app.local/api/auth/callback

SESSION_REDIS_URL=redis://redis:6379/0
SESSION_TTL_SECONDS=604800
LOGIN_STATE_TTL_SECONDS=300

APP_BASE_URL=https://app.local
API_BASE_URL=https://app.local/api
COOKIE_NAME=app_session
CSRF_COOKIE_NAME=csrf_token
COOKIE_SECURE=true
COOKIE_SAMESITE=none
COOKIE_DOMAIN=.local

DATABASE_URL=postgresql+psycopg://appuser:apppassword@host.docker.internal:5432/appdb

ALLOWED_CORS_ORIGINS=["https://app.local","http://app.local","https://localhost:3000","http://localhost:3000"]

MEDIA_STORAGE=local
MEDIA_DIR=/app/uploads
MAX_AVATAR_MB=5
