https://auth.local {
  tls internal
  encode gzip zstd
  reverse_proxy localhost:8080
}

https://api.local {
  tls internal
  encode gzip zstd
  reverse_proxy localhost:8000
}

https://app.local {
  tls internal
  encode gzip zstd

  handle_path /api/* {
    reverse_proxy localhost:8000
  }

  handle {
    reverse_proxy localhost:3000
  }
}
